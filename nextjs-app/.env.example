NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_SHOW_PARSER_DEBUG=false
NEXT_PUBLIC_ENABLE_ANALYTICS_DASHBOARD=false
NEXT_PUBLIC_ENABLE_PRICE_EXPERIMENT=false
NEXT_PUBLIC_PRICE_CONTROL_CENTS=299
NEXT_PUBLIC_PRICE_TEST_CENTS=499

# Affiliate links (leave blank until partner IDs are approved)
# Each slot stays on a safe, free fallback until you paste a real tracking URL.
# Nothing labeled "(Partner)" shows to users unless the matching var is set.
# See docs/affiliate-setup.md for which programs to apply to.
NEXT_PUBLIC_AFFILIATE_PLANS_URL=
NEXT_PUBLIC_AFFILIATE_RIGHTS_URL=
NEXT_PUBLIC_AFFILIATE_APPEALS_GUIDE_URL=
NEXT_PUBLIC_AFFILIATE_COVERAGE_URL=
# Professional bill negotiation / patient advocacy (reputable, transparent only)
NEXT_PUBLIC_AFFILIATE_BILL_HELP_URL=
# HSA/FSA provider (established, low-fee custodians)
NEXT_PUBLIC_AFFILIATE_HSA_URL=

# Google AdSense — leave blank until account is approved
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=
